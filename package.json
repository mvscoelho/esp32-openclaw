{
  "name": "esp32-openclaw",
  "version": "1.0.2-mvp",
  "description": "ESP32 Voice Channel Plugin for OpenClaw – connects esp32-openclaw-server via xiaozhi firmware",
  "type": "module",
  "main": "./index.ts",
  "files": [
    "index.ts",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": ["./index.ts"],
    "channel": {
      "id": "esp32",
      "label": "ESP32-OpenClaw",
      "selectionLabel": "ESP32 Voice (小智)",
      "docsPath": "/channels/esp32",
      "aliases": ["xiaozhi", "esp32"],
      "order": 80
    },
    "install": {
      "localPath": ".",
      "defaultChoice": "local"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --watch dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "@vitest/coverage-v8": "^2.1.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
