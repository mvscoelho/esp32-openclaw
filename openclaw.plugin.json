{
  "id": "esp32-openclaw",
  "channels": ["esp32"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "serverUrl": {
        "type": "string",
        "description": "WebSocket URL of esp32-openclaw-server /plugin endpoint (ws://host:8989/plugin)"
      },
      "appToken": {
        "type": "string",
        "description": "Bearer token for server authentication"
      },
      "defaultAgent": {
        "type": "string",
        "default": "main",
        "description": "Default OpenClaw Agent ID when device doesn't specify one"
      },
      "session": {
        "type": "object",
        "properties": {
          "scope": {
            "type": "string",
            "enum": ["per-user", "per-device"],
            "default": "per-user"
          }
        }
      }
    },
    "required": ["serverUrl"]
  }
}
